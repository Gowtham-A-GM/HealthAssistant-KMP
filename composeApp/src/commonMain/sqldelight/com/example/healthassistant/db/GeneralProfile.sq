CREATE TABLE GeneralProfile (
    question_id TEXT NOT NULL PRIMARY KEY,
    question_text TEXT NOT NULL,
    answer_json TEXT NOT NULL
);

insertOrReplace:
INSERT OR REPLACE INTO GeneralProfile(question_id, question_text, answer_json)
VALUES (?, ?, ?);

getAll:
SELECT * FROM GeneralProfile;

getByQuestionId:
SELECT * FROM GeneralProfile WHERE question_id = ?;

deleteByQuestionId:
DELETE FROM GeneralProfile WHERE question_id = ?;

deleteAll:
DELETE FROM GeneralProfile;